      "Bash(cmd //c \"mvn compile -DskipTests 2>&1 | grep -A 20 \\\\\"COMPILATION ERROR\\\\\"\")",
      "Bash(cmd //c \"mvn compile -DskipTests 2>&1 | tail -20\")",
      "Bash(cmd //c \"mvn compile -DskipTests 2>&1 | grep -i error\")",
      "Bash(cmd //c \"mvn compile -DskipTests 2>&1 | tail -10\")"
    ]
  }
